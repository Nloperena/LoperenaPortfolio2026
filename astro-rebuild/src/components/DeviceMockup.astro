---
interface Props {
  image?: string;
  link?: string;
  title?: string;
  projectId?: string;
}

const { image, link, title, projectId = 'preview' } = Astro.props;
const hostname = link?.replace('https://', '').replace('www.', '') ?? 'ARTIFACT.IO';
---

<div class="mockup-responsive-container group w-full">
  <div class="hidden md:block">
    <div class="relative mx-auto w-full">
      <div class="relative rounded-2xl bg-background-dark shadow-2xl overflow-hidden border border-accent/20 transition-all duration-500 group-hover:shadow-highlight/5 group-hover:border-highlight/20">
        <div class="h-10 bg-black/20 flex items-center px-6 gap-3 border-b border-white/5">
          <div class="flex gap-1.5">
            <div class="w-2 h-2 rounded-full bg-accent-sage/30 group-hover:bg-accent-sage transition-colors"></div>
            <div class="w-2 h-2 rounded-full bg-highlight/30 group-hover:bg-highlight transition-colors"></div>
            <div class="w-2 h-2 rounded-full bg-accent/30 group-hover:bg-accent transition-colors"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="bg-white/5 px-4 py-1 rounded-full text-[11px] text-foreground-light/30 font-mono tracking-[0.2em] truncate max-w-[400px]">
              {hostname.toUpperCase()}
            </div>
          </div>
        </div>

        <div class="aspect-[16/10] bg-white relative overflow-hidden">
          {image ? (
            <img src={image} alt={title} class="w-full h-full object-cover object-top" loading="lazy" decoding="async" />
          ) : (
            <div class="w-full h-full flex flex-col items-center justify-center gap-4 bg-gradient-to-br from-background via-background to-accent/[0.08] text-accent/40">
              <span class="font-black text-5xl tracking-tighter text-accent/30">{title?.slice(0, 2).toUpperCase() ?? 'NL'}</span>
              {link && (
                <a
                  href={link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-[10px] uppercase tracking-[0.2em] px-4 py-2 border border-accent/30 text-foreground/70 hover:bg-foreground hover:text-background transition-colors"
                >
                  Open live site ↗
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="block md:hidden">
    <div class="relative mx-auto w-full max-w-[280px]">
      <div class="relative rounded-[3rem] bg-background-dark p-3 shadow-2xl border-[8px] border-accent/20 overflow-hidden aspect-[9/19.5]">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-7 bg-black/40 rounded-b-2xl z-20 flex items-center justify-center">
          <div class="w-3 h-3 rounded-full bg-background-dark border border-white/5"></div>
        </div>
        <div class="w-full h-full bg-white rounded-[2.5rem] overflow-hidden relative">
          {image ? (
            <img src={image} alt={title} class="w-full h-full object-cover object-top" loading="lazy" decoding="async" />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-background to-accent/[0.08] text-accent/30 font-serif italic">
              {link ? (
                <a href={link} target="_blank" rel="noopener noreferrer" class="font-mono text-[9px] uppercase tracking-widest px-3 py-2 border border-accent/30">
                  Open ↗
                </a>
              ) : (
                'Preview'
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</div>
