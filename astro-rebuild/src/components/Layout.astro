---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import { Nav } from './Nav';
import { FinalCTA } from './FinalCTA';
import { BlueprintBackground } from './BlueprintBackground';
import { IntakeModal } from './IntakeModal';
import { StackRibbon } from './StackRibbon';
import { TransitionScroll } from './TransitionScroll';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { siteProfile } from '../data/site';
import { localSeo, seoKeywords } from '../data/localSeo';

interface Props {
	title: string;
	description?: string;
	canonicalPath?: string;
	ogImage?: string;
	ogType?: 'website' | 'profile' | 'article';
	articlePublishedTime?: string;
	articleModifiedTime?: string;
	noindex?: boolean;
}

const {
	title,
	description = `${siteProfile.name} - ${siteProfile.titleExtended}`,
	canonicalPath = '/',
	ogImage: ogImagePath = siteProfile.ogImage,
	ogType = 'website',
	articlePublishedTime,
	articleModifiedTime,
	noindex = false,
} = Astro.props;
const canonicalUrl = new URL(canonicalPath, siteProfile.siteUrl).href;
const ogImage = new URL(ogImagePath, siteProfile.siteUrl).href;
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content={robotsContent} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={seoKeywords} />
		<meta name="geo.region" content="US-FL" />
		<meta name="geo.placename" content={`${localSeo.city}, ${localSeo.region}`} />
		<meta name="geo.position" content={`${localSeo.geo.latitude};${localSeo.geo.longitude}`} />
		<meta name="ICBM" content={`${localSeo.geo.latitude}, ${localSeo.geo.longitude}`} />
		<meta property="og:locale" content="en_US" />
		<meta property="og:site_name" content={siteProfile.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:type" content={ogType} />
		<meta property="og:image" content={ogImage} />
		{articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
		{articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
		{ogType === 'article' && <meta property="article:author" content={siteProfile.legalName} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<link rel="alternate" type="application/rss+xml" title={`${siteProfile.name} Blog RSS`} href="/rss.xml" />
		
		<link rel="preload" as="image" href="/professional-photo.webp" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..900&family=IBM+Plex+Mono:wght@400;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..900&family=IBM+Plex+Mono:wght@400;700&display=swap"></noscript>
		<ClientRouter fallback="swap" />
		<Analytics />
		<SpeedInsights />
	</head>
	<body class="min-h-screen flex flex-col relative text-foreground selection:bg-highlight/30">
		<TransitionScroll client:load />
		<BlueprintBackground client:load transition:persist="blueprint" />
		
		<!-- Command Center Intake Modal -->
		<IntakeModal client:load transition:persist="intake-modal" />

		<!-- Stack Ribbon Drawer -->
		<StackRibbon client:load transition:persist="stack-ribbon" />
		
		<div class="relative z-10 min-h-screen bg-transparent">
			<Nav client:load transition:persist="nav" />
			<div class="w-full bg-background relative z-20 pb-24 min-h-screen">
				<slot />
			</div>
			<FinalCTA client:visible />
		</div>
	</body>
</html>







