---
import { type Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="group border border-accent/10 p-8 rounded-sm hover:shadow-2xl hover:shadow-accent/5 transition-all bg-white/50 backdrop-blur-sm overflow-hidden flex flex-col md:flex-row gap-8">
  {project.image && (
    <div class="md:w-1/3 aspect-[4/3] overflow-hidden rounded-sm border border-accent/5">
      <img 
        src={project.image} 
        alt={project.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
  )}
  
  <div class="flex-1 flex flex-col">
    <div class="flex justify-between items-start mb-6">
      <span class="text-xs font-mono text-secondary font-bold uppercase tracking-widest">{project.year}</span>
      <div class="flex gap-2">
        {project.tags.slice(0, 3).map(tag => (
          <span class="text-[11px] px-2 py-0.5 border border-accent/20 text-accent uppercase font-bold tracking-tighter">{tag}</span>
        ))}
      </div>
    </div>
    
    <h3 class="text-3xl font-bold mb-4 font-serif group-hover:text-accent transition-colors">{project.title}</h3>
    <p class="text-foreground/70 text-base leading-relaxed mb-8 flex-1">
      {project.longDescription}
    </p>
    
    <div class="flex items-center justify-between mt-auto pt-6 border-t border-accent/5">
      <div class="flex flex-wrap gap-3">
        {project.tags.slice(3).map(tag => (
          <span class="text-xs text-secondary font-bold uppercase tracking-widest">{tag}</span>
        ))}
      </div>
      
      <a 
        href={project.link} 
        target="_blank" 
        class="text-xs font-bold text-accent uppercase tracking-widest hover:underline flex items-center gap-2"
      >
        Live Demo 
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </a>
    </div>
  </div>
</div>







