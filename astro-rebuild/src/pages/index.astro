---
import Layout from '../components/Layout.astro';
import { Hero } from '../components/Hero';
import { Capabilities } from '../components/Capabilities';
import { ProjectsSectionHome } from '../components/ProjectsSectionHome';
import { Proof } from '../components/Proof';

---

<Layout title="Nico Loperena | Senior Full-Stack Developer">
	<!-- Schema.org Structured Data -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Person",
		"name": "Nicholas Loperena",
		"alternateName": "Nick Loperena",
		"jobTitle": "Senior Software Architect",
		"url": "https://nicoloperena.com",
		"sameAs": [
			"https://www.linkedin.com/in/nicholas-loperena-022813185/"
		],
		"knowsAbout": ["Web Development", "E-Commerce", "Performance Engineering", "React", "Next.js", "Astro"],
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Orlando",
			"addressRegion": "FL",
			"addressCountry": "US"
		}
	})} />

	<div class="space-y-32 md:space-y-48 pb-40">
		<!-- Hero (Editorial Brutalism) with Framer Motion -->
		<Hero client:load />

		<!-- Unified Integrity & Impact Section (Full Width) -->
		<Capabilities client:visible />

		<!-- Projects -->
		<ProjectsSectionHome client:visible />

		<!-- Engineered for Impact Proof Block -->
		<Proof client:visible />
	</div>
</Layout>
