export const prerender = true;

---
import Layout from '../components/Layout.astro';
import { PageHero } from '../components/PageHero';
import { ProjectsSection } from '../components/ProjectsSection';
import { pageSeo } from '../data/seo';
import { pageImages } from '../data/pageImages';
import { breadcrumbJsonLd, projectsJsonLd } from '../lib/schema';

const seo = pageSeo.work;
---

<Layout
	title={seo.title}
	description={seo.description}
	canonicalPath={seo.path}
	ogImage={pageImages.work.og}
	ogImageAlt={pageImages.work.alt}
	ogType={seo.ogType}
>
	<script type="application/ld+json" set:html={JSON.stringify(projectsJsonLd())} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd([
		{ name: 'Home', path: '/' },
		{ name: 'Work', path: '/work' },
	]))} />

	<div transition:name="page-hero">
		<PageHero page="work" client:load />
	</div>
	<div transition:name="page-body">
		<ProjectsSection client:idle />
	</div>
</Layout>
