---
import Layout from '../components/Layout.astro';
import { PageHero } from '../components/PageHero';
import { ProjectsSection } from '../components/ProjectsSection';
---

<Layout title="Work | Nico Loperena" description="Selected production work — B2B storefronts, e-commerce platforms, and full-stack web applications built with React, Next.js, Astro, and PostgreSQL.">
  <div transition:name="page-hero">
    <PageHero page="work" client:load />
  </div>
  <div transition:name="page-body">
    <ProjectsSection client:idle />
  </div>
</Layout>
