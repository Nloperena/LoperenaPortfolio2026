---
export const prerender = true;

import Layout from '../../components/Layout.astro';
import { PageHero } from '../../components/PageHero';
import { pageSeo, absoluteUrl } from '../../data/seo';
import { pageImages } from '../../data/pageImages';
import { formatPostDate, getPublishedPosts, getPostAudience, postPath } from '../../lib/blog';
import { blogIndexJsonLd, breadcrumbJsonLd } from '../../lib/schema';

const seo = pageSeo.blog;
const posts = await getPublishedPosts();
const recruiterPosts = posts.filter((post) => getPostAudience(post) === 'recruiter');
const engineeringPosts = posts.filter((post) => getPostAudience(post) === 'engineering');
const blogSchemaPosts = posts.map((post) => ({
  title: post.data.title,
  url: absoluteUrl(postPath(post.id)),
  date: post.data.pubDate.toISOString(),
}));
---

<Layout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.path}
  ogImage={pageImages.blog.og}
  ogType={seo.ogType}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogIndexJsonLd(blogSchemaPosts))} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
  ]))} />

  <div transition:name="page-hero">
    <PageHero page="blog" client:load />
  </div>

  <div transition:name="page-body" class="px-4 md:px-8 pb-32">
    <section class="mx-auto max-w-[1400px] border-t border-accent/20 pt-16">
      <div class="mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="font-mono text-[10px] font-bold uppercase tracking-[0.28em] text-accent">For recruiters & employers</p>
          <h2 class="mt-3 font-sans text-3xl md:text-5xl font-black uppercase tracking-tighter text-foreground">
            Kissimmee · Remote · Full-stack
          </h2>
          <p class="mt-4 max-w-2xl font-serif text-base md:text-lg italic text-foreground/70">
            Hiring guides for engineering leaders, plus technical notes from production work in React, Next.js, and PostgreSQL.
          </p>
        </div>
        <a
          href="/rss.xml"
          class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-foreground/70 hover:text-foreground transition-colors"
        >
          RSS feed →
        </a>
      </div>

      <div class="mb-16 border-b border-accent/20 pb-16">
        <h2 class="font-sans text-2xl md:text-4xl font-black uppercase tracking-tighter text-foreground">
          Hiring & remote delivery
        </h2>
        <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-2">
          {recruiterPosts.map((post) => (
            <article class="group flex flex-col border border-accent/20 bg-white/40 hover:bg-white/70 transition-colors">
              <a href={postPath(post.id)} class="block overflow-hidden border-b border-accent/15">
                <img
                  src={post.data.ogImage ?? pageImages.blog.og}
                  alt={post.data.title}
                  width="1200"
                  height="675"
                  class="aspect-[16/9] w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                  decoding="async"
                />
              </a>
              <div class="flex flex-1 flex-col p-6 md:p-8">
                <time datetime={post.data.pubDate.toISOString()} class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-accent">
                  {formatPostDate(post.data.pubDate)}
                </time>
                <h3 class="mt-4 font-sans text-xl md:text-2xl font-bold uppercase tracking-tight text-foreground">
                  <a href={postPath(post.id)} class="hover:text-accent transition-colors">
                    {post.data.title}
                  </a>
                </h3>
                <p class="mt-3 flex-1 font-serif text-base leading-relaxed text-foreground/75">
                  {post.data.description}
                </p>
                <a
                  href={postPath(post.id)}
                  class="mt-6 inline-flex items-center gap-2 font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-foreground group-hover:text-accent transition-colors"
                >
                  Read article <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div>
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.28em] text-accent">Engineering notes</p>
        <h2 class="mt-3 font-sans text-2xl md:text-4xl font-black uppercase tracking-tighter text-foreground">
          Production patterns & stack
        </h2>
        <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-3">
          {engineeringPosts.map((post) => (
          <article class="group flex flex-col border border-accent/20 bg-white/40 hover:bg-white/70 transition-colors">
            <a href={postPath(post.id)} class="block overflow-hidden border-b border-accent/15">
              <img
                src={post.data.ogImage ?? pageImages.blog.og}
                alt={post.data.title}
                width="1200"
                height="675"
                class="aspect-[16/9] w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
                decoding="async"
              />
            </a>
            <div class="flex flex-1 flex-col p-6 md:p-8">
              <time datetime={post.data.pubDate.toISOString()} class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-accent">
                {formatPostDate(post.data.pubDate)}
              </time>
              <h3 class="mt-4 font-sans text-xl md:text-2xl font-bold uppercase tracking-tight text-foreground">
                <a href={postPath(post.id)} class="hover:text-accent transition-colors">
                  {post.data.title}
                </a>
              </h3>
              <p class="mt-3 flex-1 font-serif text-base leading-relaxed text-foreground/75">
                {post.data.description}
              </p>
              <div class="mt-5 flex flex-wrap gap-2">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="border border-accent/20 px-2 py-1 font-mono text-[9px] font-bold uppercase tracking-[0.15em] text-foreground/70">
                    {tag}
                  </span>
                ))}
              </div>
              <a
                href={postPath(post.id)}
                class="mt-6 inline-flex items-center gap-2 font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-foreground group-hover:text-accent transition-colors"
              >
                Read article <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
