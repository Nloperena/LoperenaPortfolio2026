---
export const prerender = true;

import Layout from '../../components/Layout.astro';
import { pageImages } from '../../data/pageImages';
import { absoluteUrl } from '../../data/seo';
import { formatPostDate, postPath } from '../../lib/blog';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/schema';
import { nexrenaCrossLinksByPost } from '../../data/nexrenaCrossLinks';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const url = absoluteUrl(postPath(post.id));
const ogImage = post.data.ogImage ?? pageImages.blog.og;
const nexrenaLinks = nexrenaCrossLinksByPost[post.id] ?? [];
---

<Layout
  title={`${post.data.title} | Nico Loperena`}
  description={post.data.description}
  canonicalPath={postPath(post.id)}
  ogImage={ogImage}
  ogType="article"
  articlePublishedTime={post.data.pubDate.toISOString()}
  articleModifiedTime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd({
    title: post.data.title,
    description: post.data.description,
    url,
    pubDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    image: ogImage,
    tags: post.data.tags,
  }))} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: post.data.title, path: postPath(post.id) },
  ]))} />

  <article class="px-4 md:px-8 pb-32 pt-28 md:pt-32">
    <div class="mx-auto max-w-3xl">
      <header class="mb-10 border-b border-accent/20 pb-10">
        <a href="/blog" class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-accent hover:text-foreground transition-colors">
          ← Back to blog
        </a>
        <time datetime={post.data.pubDate.toISOString()} class="mt-6 block font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-accent/80">
          {formatPostDate(post.data.pubDate)}
        </time>
        <h1 class="mt-4 font-sans text-[clamp(2rem,5vw,3.5rem)] font-black uppercase tracking-tighter leading-[0.95] text-foreground">
          {post.data.title}
        </h1>
        <p class="mt-5 font-serif text-lg md:text-xl italic leading-relaxed text-foreground/75">
          {post.data.description}
        </p>
        {post.data.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="border border-accent/20 px-2 py-1 font-mono text-[9px] font-bold uppercase tracking-[0.15em] text-foreground/70">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      {post.data.ogImage && (
        <img
          src={post.data.ogImage}
          alt={post.data.title}
          width="1200"
          height="675"
          class="mb-10 aspect-[16/9] w-full border border-accent/15 object-cover"
          loading="eager"
          decoding="async"
        />
      )}

      <div class="prose prose-lg max-w-none prose-headings:font-sans prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tight prose-p:font-serif prose-p:text-foreground/85 prose-a:text-accent prose-a:no-underline hover:prose-a:text-foreground prose-strong:text-foreground prose-li:font-serif">
        <Content />
      </div>

      {nexrenaLinks.length > 0 && (
        <aside class="mt-12 border border-accent/20 bg-white/40 p-6 md:p-8">
          <p class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-accent">Related on Nexrena</p>
          <p class="mt-2 font-serif text-sm italic text-foreground/70">
            Agency case studies and B2B growth guides on my separate commercial site.
          </p>
          <ul class="mt-5 space-y-4">
            {nexrenaLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-base font-bold text-foreground hover:text-accent transition-colors"
                >
                  {link.label} ↗
                </a>
                <p class="mt-1 font-serif text-sm text-foreground/70">{link.description}</p>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </div>
  </article>
</Layout>
