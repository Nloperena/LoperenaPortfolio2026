---
export const prerender = true;

import Layout from '../../components/Layout.astro';
import { pageImages, blogPostOgImage } from '../../data/pageImages';
import { absoluteUrl } from '../../data/seo';
import { formatPostDate, normalizePostSlug, postPath } from '../../lib/blog';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/schema';
import { nexrenaCrossLinksByPost } from '../../data/nexrenaCrossLinks';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: normalizePostSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const url = absoluteUrl(postPath(post.id));
const ogImage = post.data.ogImage ?? blogPostOgImage(post.id);
const slug = normalizePostSlug(post.id);
const nexrenaLinks = nexrenaCrossLinksByPost[slug] ?? [];
---

<Layout
  title={`${post.data.title} | Nico Loperena`}
  description={post.data.description}
  canonicalPath={postPath(post.id)}
  ogImage={ogImage}
  ogImageAlt={post.data.title}
  ogType="article"
  articlePublishedTime={post.data.pubDate.toISOString()}
  articleModifiedTime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd({
    title: post.data.title,
    description: post.data.description,
    url,
    pubDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    image: ogImage,
    tags: post.data.tags,
  }))} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: post.data.title, path: postPath(post.id) },
  ]))} />

  <article class="px-4 md:px-6 pb-32 pt-28 md:pt-32">
    <div class="mx-auto max-w-3xl border-2 border-foreground bg-background p-8 md:p-12 shadow-brutal-lg">
      <header class="mb-10 border-b-2 border-foreground pb-10">
        <a href="/blog" class="font-mono text-[10px] font-bold uppercase tracking-[0.18em] hover:bg-highlight px-1 -mx-1">
          ← Back to blog
        </a>
        <time datetime={post.data.pubDate.toISOString()} class="mt-6 block font-mono text-[10px] font-bold uppercase tracking-[0.18em]">
          {formatPostDate(post.data.pubDate)}
        </time>
        <h1 class="mt-4 font-mono text-[clamp(2rem,5vw,3rem)] font-black uppercase tracking-tighter leading-[0.95]">
          {post.data.title}
        </h1>
        <p class="mt-5 font-sans text-lg md:text-xl leading-relaxed">
          {post.data.description}
        </p>
        {post.data.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="border-2 border-foreground px-2 py-1 font-mono text-[9px] font-bold uppercase tracking-[0.15em]">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      {post.data.ogImage && (
        <img
          src={post.data.ogImage}
          alt={post.data.title}
          width="1200"
          height="675"
          class="mb-10 aspect-[16/9] w-full border-2 border-foreground object-cover"
          loading="eager"
          decoding="async"
        />
      )}

      <div class="prose prose-lg max-w-none prose-headings:font-mono prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tight prose-p:font-sans prose-p:text-foreground prose-a:text-foreground prose-a:underline prose-a:decoration-2 hover:prose-a:bg-highlight prose-strong:text-foreground prose-li:font-sans">
        <Content />
      </div>

      {nexrenaLinks.length > 0 && (
        <aside class="mt-12 border-2 border-foreground bg-concrete p-6 md:p-8">
          <p class="font-mono text-[10px] font-bold uppercase tracking-[0.18em]">Related on Nexrena</p>
          <p class="mt-2 font-sans text-sm">
            Agency case studies and B2B growth guides on my separate commercial site.
          </p>
          <ul class="mt-5 space-y-4">
            {nexrenaLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-sm font-bold uppercase hover:bg-highlight px-1 -mx-1"
                >
                  {link.label} ↗
                </a>
                <p class="mt-1 font-sans text-sm">{link.description}</p>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </div>
  </article>
</Layout>
