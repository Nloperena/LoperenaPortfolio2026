---
export const prerender = true;

import Layout from '../../components/Layout.astro';
import { formatPostDate } from '../../lib/blog';
import { caseStudyPath, normalizeCaseStudySlug } from '../../lib/caseStudies';
import { absoluteUrl } from '../../data/seo';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/schema';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies', ({ data }) => !data.draft);
  return studies.map((study) => ({
    params: { slug: normalizeCaseStudySlug(study.id) },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);
const url = absoluteUrl(caseStudyPath(study.id));
const ogImage = study.data.ogImage ?? '/og/og-work.png';
---

<Layout
  title={`${study.data.title} | Nico Loperena`}
  description={study.data.description}
  canonicalPath={caseStudyPath(study.id)}
  ogImage={ogImage}
  ogImageAlt={study.data.title}
  ogType="article"
  articlePublishedTime={study.data.pubDate.toISOString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd({
    title: study.data.title,
    description: study.data.description,
    url,
    pubDate: study.data.pubDate,
    image: ogImage,
    tags: study.data.stack,
  }))} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Work', path: '/work' },
    { name: study.data.title, path: caseStudyPath(study.id) },
  ]))} />

  <article class="px-4 md:px-6 pb-32 pt-28 md:pt-32">
    <div class="mx-auto max-w-4xl border-2 border-foreground bg-background p-8 md:p-12 shadow-brutal-lg">
      <header class="mb-10 border-b-2 border-foreground pb-10">
        <div class="flex flex-wrap items-center gap-3">
          <a href="/work" class="font-mono text-[10px] font-bold uppercase tracking-[0.18em] hover:bg-highlight px-1 -mx-1">
            ← Back to work
          </a>
          <span class="font-mono text-[10px] text-secondary">·</span>
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.18em] text-secondary">
            {study.data.industry}
          </span>
        </div>

        <time datetime={study.data.pubDate.toISOString()} class="mt-6 block font-mono text-[10px] font-bold uppercase tracking-[0.18em]">
          Case study · {study.data.year}
        </time>

        <h1 class="mt-4 font-mono text-[clamp(2rem,5vw,3rem)] font-black uppercase tracking-tighter leading-[0.95]">
          {study.data.title}
        </h1>

        <p class="mt-5 font-sans text-lg md:text-xl leading-relaxed">
          {study.data.description}
        </p>

        <p class="mt-4 font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-secondary">
          {study.data.role}
        </p>

        <div class="mt-8 grid grid-cols-2 gap-0 border-2 border-foreground sm:grid-cols-4">
          {study.data.metrics.map((metric) => (
            <div class="border-b-2 border-r-2 border-foreground bg-concrete p-4 last:border-r-0 sm:border-b-0 [&:nth-child(2n)]:border-r-0 sm:[&:nth-child(2n)]:border-r-2 sm:[&:nth-child(4n)]:border-r-0">
              <p class="font-mono text-2xl font-black tracking-tight">{metric.value}</p>
              <p class="mt-1 font-mono text-[9px] font-bold uppercase tracking-[0.14em]">{metric.label}</p>
            </div>
          ))}
        </div>

        <div class="mt-6 flex flex-wrap gap-2">
          {study.data.stack.map((tech) => (
            <span class="border-2 border-foreground px-2 py-1 font-mono text-[9px] font-bold uppercase tracking-[0.15em]">
              {tech}
            </span>
          ))}
        </div>
      </header>

      {study.data.ogImage && (
        <img
          src={study.data.ogImage}
          alt={`${study.data.title} preview`}
          width="1200"
          height="675"
          class="mb-10 aspect-[16/9] w-full border-2 border-foreground object-cover object-top"
          loading="eager"
          decoding="async"
        />
      )}

      <div class="prose prose-lg max-w-none prose-headings:font-mono prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tight prose-p:font-sans prose-p:text-foreground prose-a:text-foreground prose-a:underline prose-a:decoration-2 hover:prose-a:bg-highlight prose-strong:text-foreground prose-li:font-sans prose-table:font-sans">
        <Content />
      </div>

      {study.data.quote && (
        <blockquote class="mt-12 border-l-4 border-foreground bg-concrete p-6 md:p-8">
          <p class="font-sans text-lg italic leading-relaxed">&ldquo;{study.data.quote.text}&rdquo;</p>
          <footer class="mt-4 font-mono text-[10px] font-bold uppercase tracking-[0.18em]">
            — {study.data.quote.attribution}
          </footer>
        </blockquote>
      )}

      <div class="mt-12 flex flex-col gap-4 border-2 border-foreground bg-background p-6 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-mono text-[10px] font-bold uppercase tracking-[0.18em]">Live system</p>
          <a
            href={study.data.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 inline-block font-mono text-sm font-bold uppercase hover:bg-highlight px-1 -mx-1"
          >
            {study.data.liveUrl.replace('https://', '')} ↗
          </a>
        </div>
        <a href="/work" class="brutal-btn-ghost !text-[10px]">
          All projects →
        </a>
      </div>

      {study.data.nexrenaUrl && (
        <aside class="mt-8 border-2 border-foreground bg-concrete p-6 md:p-8">
          <p class="font-mono text-[10px] font-bold uppercase tracking-[0.18em]">Agency perspective</p>
          <p class="mt-2 font-sans text-sm leading-relaxed">
            Business-outcome case study with client context on Nexrena — my separate B2B studio site.
          </p>
          <a
            href={study.data.nexrenaUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-block font-mono text-sm font-bold uppercase hover:bg-highlight px-1 -mx-1"
          >
            View on Nexrena ↗
          </a>
        </aside>
      )}
    </div>
  </article>
</Layout>
