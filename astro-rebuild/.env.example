# DATABASE_URL=postgres://user:password@localhost:5432/intake_db
# POSTGRES_URL=postgres://user:password@host:5432/your_db

# Heroku backend (optional — if set, form POSTs here instead of /api/contact)
# PUBLIC_INTAKE_API_URL=https://loperena-intake-backend.herokuapp.com/api/submissions

# Resend email fallback for /api/contact when no DATABASE_URL (optional)
# RESEND_API_KEY=re_...
# CONTACT_TO_EMAIL=nicholasloperena@gmail.com
# RESEND_FROM=Portfolio Contact <onboarding@resend.dev>

# Password-protected /operations dashboard (required in production)
# OPS_PASSWORD=your-secret-password
# OPS_SESSION_SECRET=optional-separate-signing-secret
